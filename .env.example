APP_NAME=T&S
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://teses.test

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=forge_tes
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
# sync: análise de acórdãos roda após a resposta HTTP (não trava o Filament). Para fila real: database + php artisan queue:work
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=ses
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@tesesesumulas.com.br
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"


OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# OpenRouter (assistente de IA das estatísticas — admin)
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_MANAGEMENT=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REQUEST_TIMEOUT=120

API_TOKEN=
MATOMO_TOKEN=

# Stripe (modo TEST)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=


# Produtos Stripe (TEST)
STRIPE_PRODUCT_PRO=
STRIPE_PRODUCT_PREMIUM=

# Cashier
CASHIER_CURRENCY=brl
CASHIER_CURRENCY_LOCALE=pt_BR

# habilitar/desabilitar assinaturas
ENABLE_SUBSCRIPTIONS=false

# Google OAuth (Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tesesesumulas.com.br/auth/google/callback

#SENDY DB AND API
SENDY_API_TOKEN=
SENDY_API_BASE_URL=
SENDY_BRAND_ID=
SENDY_LIST_ID=
SENDY_LIST_INTERNAL_ID=
# false no Mac/dev (DB Sendy só acessível no servidor de prod); true em prod
SENDY_DB_ENABLED=false
SENDY_DB_HOST=
SENDY_DB_PORT=
SENDY_DB_NAME=
SENDY_DB_USER=
SENDY_DB_PASSWORD=
#(bypass double opt-in para users T&S, que já confirmaram email)
SENDY_SILENT_AUTHENTICATED=true 
# (visitantes respeitam o modo da lista)
SENDY_SILENT_VISITOR=false

SENDY_DB_ENABLED=false